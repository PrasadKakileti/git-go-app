# ─────────────────────────────────────────
# DATABASE  (MySQL local or free cloud: https://neon.tech / https://supabase.com)
# ─────────────────────────────────────────
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=job_portal

# ─────────────────────────────────────────
# EMAIL  (choose ONE: SendGrid or SMTP)
# ─────────────────────────────────────────

# Option A: SendGrid — free tier 100 emails/day  https://sendgrid.com
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Option B: Gmail SMTP
# Use an App Password (not your Gmail password): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ─────────────────────────────────────────
# JOB API  ← KEY NEW ADDITION
# Fetches real jobs from LinkedIn, Indeed, Glassdoor, ZipRecruiter
# Free tier: 200 req/month — enough for dev + small deployment
# Sign up FREE: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# ─────────────────────────────────────────
JSEARCH_API_KEY=your-rapidapi-key-here

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# Admin login (loaded from env — never hardcoded in source)
ADMIN_EMAIL=admin@jobhub.com
ADMIN_PASSWORD=change-this-to-a-strong-password
